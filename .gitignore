# İlk commit'ten ÖNCE db.php'yi db.example.php olarak yeniden adlandırın
# ve bu satırı aktif hale getirin:
# htdocs/includes/db.php

# ========================
# Yüklenen Dosyalar (Kullanıcı Verileri)
# ========================
